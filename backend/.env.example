OPENAI_API_KEY=
FIREWORKS_API_KEY=
FIREWORKS_BASE_URL=https://api.fireworks.ai/inference/v1
# Model identifier for the chat-completion endpoint.
# Defaults to "accounts/fireworks/routers/kimi-k2p6-turbo" if unset.
# Set to "umans-coder" when using the umans Code Pro Plan.
FIREWORKS_MODEL=
# Timeout in seconds for Fireworks AI chat-completion calls.
# Defaults to 300. Raise for slower providers (e.g. umans), lower for faster ones.
FIREWORKS_TIMEOUT=
# Path to the ffmpeg binary. Defaults to "ffmpeg" (resolved via PATH).
# Set this if ffmpeg is not on PATH, e.g. CONDUIT_FFMPEG_PATH=C:\tools\ffmpeg\bin\ffmpeg.exe
CONDUIT_FFMPEG_PATH=
